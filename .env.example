# ===========================================
# StockFlow 环境变量配置模板
# ===========================================
# 复制此文件为 .env.production 并填写实际值
# ===========================================

# ===== 业务后端 (Backend) =====
NODE_ENV=production
PORT=3000

# 数据库配置 (PostgreSQL)
DB_HOST=your-database-host.com
DB_PORT=5432
DB_USERNAME=your_db_user
DB_PASSWORD=your_secure_password
DB_NAME=inventory

# Redis 配置
REDIS_HOST=your-redis-host.com
REDIS_PORT=6379

# JWT 配置
JWT_SECRET=your-very-secure-jwt-secret-key-minimum-32-characters
JWT_EXPIRES_IN=7d

# CORS 配置 (前端域名)
CORS_ORIGIN=https://stockflow-frontend.vercel.app,https://stockflow-admin-frontend.vercel.app

# ===== 管理后台后端 (Admin Backend) =====
ADMIN_PORT=3001
ADMIN_DB_NAME=admin_db
ADMIN_JWT_SECRET=your-admin-jwt-secret-key-different-from-backend

# ===== 前端环境变量 =====
VITE_API_BASE_URL=https://stockflow-backend.onrender.com/api
VITE_APP_TITLE=StockFlow 库存管理系统

# ===== 管理后台前端环境变量 =====
VITE_ADMIN_API_BASE_URL=https://stockflow-admin-backend.onrender.com/api
VITE_ADMIN_APP_TITLE=StockFlow 管理后台